import time
import random
from datetime import datetime

G = "\033[92m"
B = "\033[94m"
Y = "\033[93m"
R = "\033[91m"
W = "\033[0m"


class DecodeLabsPPRobot:
    def __init__(self):
        self.knowledge_base = {
            "greeting": {
                "keywords": ["hi", "hello", "hey", "greetings"],
                "responses": [
                    "Hello! How can I assist you today?",
                    "Hi there! What can I do for you?",
                    "Greetings! How may I help you?"
                ]
            },
            "status": {
                "keywords": ["how are you", "how's it going"],
                "responses": [
                    "I am just a program, but I am functioning as expected!"
                ]
            },
            "contact": {
                "keywords": ["contact", "email", "location"],
                "responses": [
                    "You can reach us at: ",
                    "contact: +1-234-567-8901",
                    "Email: decodelabs.tech@gmail.com",
                    "location: banglore, karnataka, india"
                ]
            },
            "ai_logic": {
                "keywords": ["ai logic", "how do you work", "explain your logic"],
                "responses": [
                    "I use keyword matching to understand your questions and respond accordingly."
                ]
            },
            "thanks": {
                "keywords": ["thanks", "thank you", "appreciate it"],
                "responses": [
                    "You're welcome!",
                    "No problem!",
                    "Glad I could help!"
                ]
            }
        }

        self.is_running = True

    def typing_effect(self, text):
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        print(f"{G}[{timestamp}] BOT: {W}", end="", flush=True)

        for char in text:
            print(char, end="", flush=True)
            time.sleep(0.03)

        print()

    def get_response(self, user_input):
        clean_input = user_input.lower().strip()

        # Exit
        if clean_input in ["exit", "bye"]:
            self.is_running = False
            return "Goodbye! Have a great day!"

        # Search knowledge base
        for category in self.knowledge_base.values():
            for keyword in category["keywords"]:
                if keyword in clean_input:
                    return random.choice(category["responses"])

        # Default response
        return "Sorry, I don't understand that. Please try asking something else."

    def start(self):
        user_name = input(f"{B}Enter your name: {W}")

        self.typing_effect(
            f"Hello {user_name}! I am DecodeLabsPPRobot. How can I assist you today?"
        )

        while self.is_running:
            try:
                user_msg = input(f"{Y}{user_name}: {W}")

                if not user_msg.strip():
                    continue

                response = self.get_response(user_msg)
                self.typing_effect(response)

            except KeyboardInterrupt:
                print("\nInterrupted by user.")
                break

        print(f"{R}Exiting...{W}")


if __name__ == "__main__":
    bot = DecodeLabsPPRobot()
    bot.start()
